# Port the BFF server listens on
PORT=9001

# Full URL of the handläggare list endpoint on the handläggning service
# Used by GET /handlaggare
HANDLAGGARE_URL=https://handlaggning.internal.example.com/handlaggare

# Base URL of the OUL service
# Used by GET /tasks/:handlaggarId and POST /tasks/getNext/:handlaggarId
BE_OUL_URL=https://oul.internal.example.com
